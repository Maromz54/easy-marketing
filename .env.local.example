# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Facebook App (Meta for Developers)
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Security
# Generate with: openssl rand -hex 32  (or any strong random string)
# Vercel automatically sends this as "Authorization: Bearer {CRON_SECRET}"
# when invoking cron routes. Add the same value in Vercel Project Settings > Env Vars.
CRON_SECRET=your-strong-random-secret-here
